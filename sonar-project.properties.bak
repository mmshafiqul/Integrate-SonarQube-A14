# SonarQube Project Configuration
sonar.projectKey=react-nodejs-postgress-application
sonar.projectName=React NodeJS PostgreSQL Application
sonar.projectVersion=1.0

# Source code location
sonar.sources=backend,frontend/src

# Exclude node_modules and build directories
sonar.exclusions=**/node_modules/**,**/dist/**,**/build/**,**/.git/**

# JavaScript configuration
sonar.javascript.lcov.reportPaths=coverage/lcov.info
sonar.coverage.exclusions=**/node_modules/**,**/dist/**,**/build/**

# Encoding
sonar.sourceEncoding=UTF-8

# SonarQube server URL (replace with your SonarQube server URL)
sonar.host.url=http://localhost:9000

# Authentication token (use SONAR_TOKEN environment variable or pass via CLI)
sonar.login=${SONAR_TOKEN}
